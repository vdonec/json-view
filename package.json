{
  "name": "@vdonec/json-view",
  "version": "1.0.2",
  "description": "This is a javascript library for displaying json data into a DOM",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/jsonview.umd.cjs",
  "module": "dist/jsonview.js",
  "exports": {
    ".": {
      "types": "./dist/jsonview.d.ts",
      "import": "./dist/jsonview.js",
      "require": "./dist/jsonview.umd.cjs"
    },
    "./style.css": "./dist/jsonview.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vdonec/json-view.git"
  },
  "homepage": "https://github.com/vdonec/json-view#readme",
  "bugs": {
    "url": "https://github.com/vdonec/json-view/issues"
  },
  "keywords": [
    "json",
    "json-viewer",
    "json-tree",
    "expand",
    "collapse"
  ],
  "author": {
    "name": "Pavel Grabovets",
    "url": "https://github.com/vdonec"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "vite": "8.0.3"
  }
}
